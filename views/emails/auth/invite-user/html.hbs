<html lang='en'>
    <head>
        <meta charset='utf-8' />
        <meta name='viewport' content='width=device-width, initial-scale=1' />
        <title>Glee invitation</title>
    </head>
    <body
        style='margin: 0; padding: 0; background: #f5f7fb; color: #111827; font-family: Arial, Helvetica, sans-serif;'
    >
        <table role='presentation' width='100%' cellspacing='0' cellpadding='0'>
            <tr>
                <td style='padding: 32px 16px;'>
                    <table
                        role='presentation'
                        width='100%'
                        cellspacing='0'
                        cellpadding='0'
                        style='max-width: 560px; margin: 0 auto; background: #ffffff; border: 1px solid #e5e7eb; border-radius: 18px; overflow: hidden; box-shadow: 0 18px 40px rgba(17, 24, 39, 0.08);'
                    >
                        <tr>
                            <td style='padding: 28px 30px 10px;'>
                                {{#if logoUrl}}
                                    <img
                                        src='{{logoUrl}}'
                                        alt='Glee'
                                        style='height: 38px; width: auto; display: block; margin: 0 0 14px;'
                                    />
                                {{else}}
                                    <div
                                        style='font-size: 21px; font-weight: 800; color: #111827;'
                                    >Glee</div>
                                {{/if}}
                                <div
                                    style='height: 4px; width: 44px; background: #7c3aed; border-radius: 999px;'
                                ></div>
                            </td>
                        </tr>
                        <tr>
                            <td style='padding: 12px 30px 30px;'>
                                <p
                                    style='margin: 0 0 10px; color: #7c3aed; font-size: 11px; font-weight: 800; letter-spacing: 1.8px; text-transform: uppercase;'
                                >Team invitation</p>
                                <h1
                                    style='margin: 0 0 14px; color: #111827; font-size: 25px; line-height: 1.18; font-weight: 800;'
                                >You have been invited to Glee</h1>
                                <p
                                    style='margin: 0 0 18px; color: #4b5563; font-size: 15px; line-height: 1.6;'
                                >Hello {{name}}, you have been invited to join
                                    Glee with the
                                    <strong style='color: #111827;'>{{role}}</strong>
                                    role. Accept the invitation to set your password
                                    and finish account setup.</p>
                                <p style='margin: 0 0 20px;'>
                                    <a
                                        href='{{link}}'
                                        style='display: inline-block; background: #111827; color: #ffffff; text-decoration: none; padding: 13px 18px; border-radius: 10px; font-size: 14px; font-weight: 700;'
                                    >Accept invitation</a>
                                </p>
                                <div
                                    style='padding: 14px 16px; background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 12px;'
                                >
                                    <p
                                        style='margin: 0 0 8px; color: #6b7280; font-size: 13px; line-height: 1.6;'
                                    >Button not working? Open this link:</p>
                                    <p
                                        style='margin: 0; color: #111827; font-size: 12px; line-height: 1.6; word-break: break-all;'
                                    >{{link}}</p>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td
                                style='padding: 18px 30px 24px; border-top: 1px solid #eef2f7; color: #9ca3af; font-size: 12px; line-height: 1.7;'
                            >
                                Need help?
                                <a
                                    href='mailto:no-reply@dmhub.cloud'
                                    style='color: #7c3aed; font-weight: 700; text-decoration: none;'
                                >no-reply@dmhub.cloud</a><br />
                                &copy;
                                {{date}}
                                Glee. All rights reserved.
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </body>
</html>
