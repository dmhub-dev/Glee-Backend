<html lang='en'>
  <head><meta charset='utf-8' /><title>Vendor event pending approval</title></head>
  <body style='font-family: Arial, sans-serif; color:#111827; margin:0; padding:24px; background:#f8fafc;'>
    <table width='100%' cellspacing='0' cellpadding='0' style='max-width:560px;margin:0 auto;background:#ffffff;border:1px solid #e5e7eb;'>
      <tr><td style='padding:24px;'>
        {{#if logoUrl}}<img src='{{logoUrl}}' alt='Glee' style='height:40px;margin-bottom:24px;' />{{/if}}
        <h1 style='font-size:22px;line-height:1.3;margin:0 0 16px;'>Vendor event needs approval</h1>
        <p style='font-size:15px;line-height:1.6;margin:0 0 16px;'><strong>{{vendorName}}</strong> has submitted <strong>{{eventName}}</strong> for review.</p>
        <p style='font-size:14px;line-height:1.6;margin:0 0 20px;color:#4b5563;'>
          Vendor: {{vendorEmail}}<br />
          Date: {{eventDate}}<br />
          Location: {{eventLocation}}
        </p>
        <p style='margin:0 0 24px;'><a href='{{reviewUrl}}' style='display:inline-block;background:#111827;color:#ffffff;text-decoration:none;padding:12px 18px;font-size:14px;'>Review event</a></p>
        <p style='font-size:12px;line-height:1.6;color:#9ca3af;margin:0;'>Glee Admin Notification · {{year}}</p>
      </td></tr>
    </table>
  </body>
</html>
