<html xmlns='http://www.w3.org/1999/xhtml'>
    <head>
        <meta charset='UTF-8' />
        <meta content='width=device-width, initial-scale=1' name='viewport' />
        <meta http-equiv='X-UA-Compatible' content='IE=edge' />
        <meta name='x-apple-disable-message-reformatting' />
        <meta content='telephone=no' name='format-detection' />
        <title>Your Ticket - {{productTitle}}</title>
        <style type='text/css'>
            body, table, td, a { -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%; } table, td { mso-table-lspace: 0pt;
            mso-table-rspace: 0pt; border-collapse: collapse; } img {
            -ms-interpolation-mode: bicubic; border: 0; outline: none;
            text-decoration: none; } body { margin: 0; padding: 0; background:
            #f5f7fb; color: #111827; font-family: Arial, Helvetica, sans-serif; }
            a { color: #7c3aed; text-decoration: none; } .shell { padding: 32px
            16px; background: #f5f7fb; } .card { max-width: 640px; margin: 0 auto;
            background: #ffffff; border: 1px solid #e5e7eb; border-radius: 18px;
            overflow: hidden; box-shadow: 0 18px 40px rgba(17,24,39,0.08); }
            .brand { padding: 28px 30px 10px; } .brand-name { font-size: 21px;
            font-weight: 800; color: #111827; } .accent { height: 4px; width:
            44px; background: #7c3aed; border-radius: 999px; margin-top: 14px; }
            .section { padding: 12px 30px 30px; } .eyebrow { margin: 0 0 10px;
            color: #7c3aed; font-size: 11px; font-weight: 800; letter-spacing:
            1.8px; text-transform: uppercase; } .title { margin: 0 0 14px; color:
            #111827; font-size: 28px; line-height: 1.16; font-weight: 800; }
            .copy { margin: 0; color: #4b5563; font-size: 15px; line-height: 1.6;
            } .event-box { margin: 22px 0; padding: 18px; background: #f8fafc;
            border: 1px solid #e5e7eb; border-radius: 14px; } .event-name {
            margin: 0 0 10px; color: #111827; font-size: 20px; line-height: 1.25;
            font-weight: 800; } .meta { margin: 0; color: #6b7280; font-size:
            13px; line-height: 1.6; } .ticket-box { margin: 0 0 22px; background:
            #ffffff; border: 1px solid #ddd6fe; border-radius: 14px; overflow:
            hidden; } .ticket-head { padding: 16px 18px; background: #fbfaff;
            border-bottom: 1px solid #ede9fe; } .ticket-label { margin: 0 0 4px;
            color: #7c3aed; font-size: 10px; font-weight: 800; letter-spacing:
            1.6px; text-transform: uppercase; } .ticket-title { margin: 0; color:
            #111827; font-size: 18px; line-height: 1.3; font-weight: 800; }
            .ticket-body { padding: 18px; } .detail-label { margin: 0 0 4px;
            color: #9ca3af; font-size: 10px; font-weight: 800; letter-spacing:
            1.4px; text-transform: uppercase; } .detail-value { margin: 0 0 14px;
            color: #111827; font-size: 14px; line-height: 1.45; font-weight: 700;
            } .detail-value.small { color: #374151; font-size: 12px; word-break:
            break-all; } .pdf-panel { padding: 16px; text-align: center; background:
            #f8fafc; border: 1px solid #e5e7eb; border-radius: 12px; } .pdf-title {
            margin: 0 0 6px; color: #111827; font-size: 14px; font-weight: 800; }
            .pdf-copy { margin: 0; color: #6b7280; font-size: 12px; line-height:
            1.55; } .link-panel { margin: 0 0 22px; padding: 18px; background:
            #111827; border-radius: 14px; } .link-title { margin: 0 0 8px;
            color: #ffffff; font-size: 16px; line-height: 1.35; font-weight: 800; }
            .link-copy { margin: 0 0 14px; color: #d1d5db; font-size: 13px;
            line-height: 1.6; } .ticket-link-row { padding: 12px 0; border-top:
            1px solid rgba(255,255,255,0.12); } .ticket-link-button { display:
            inline-block; padding: 11px 14px; background: #ffffff; color: #111827
            !important; border-radius: 10px; font-size: 13px; font-weight: 800; }
            .summary { margin: 0 0 20px; border: 1px solid #e5e7eb;
            border-radius: 14px; overflow: hidden; } .summary-head { padding: 12px
            16px; background: #f8fafc; color: #111827; font-size: 12px;
            font-weight: 800; letter-spacing: 1.4px; text-transform: uppercase; }
            .row { padding: 11px 16px; border-top: 1px solid #f1f5f9; }
            .row-label { color: #6b7280; font-size: 13px; line-height: 1.45; }
            .row-value { color: #111827; font-size: 13px; line-height: 1.45;
            font-weight: 800; text-align: right; } .total-row { padding: 14px
            16px; border-top: 1px solid #e5e7eb; background: #fbfaff; }
            .total-label { color: #111827; font-size: 14px; font-weight: 800; }
            .total-value { color: #7c3aed; font-size: 16px; font-weight: 900;
            text-align: right; } .notice { margin: 0; padding: 14px 16px;
            background: #fbfaff; border: 1px solid #ede9fe; border-radius: 12px;
            color: #5b21b6; font-size: 13px; line-height: 1.65; } .footer {
            padding: 18px 30px 24px; border-top: 1px solid #eef2f7; color: #9ca3af;
            font-size: 12px; line-height: 1.7; } .footer a { color: #7c3aed;
            font-weight: 700; } @media screen and (max-width: 480px) { .shell {
            padding: 18px 10px !important; } .brand, .section, .footer { padding-left:
            18px !important; padding-right: 18px !important; } .title { font-size:
            23px !important; } .ticket-body td { display: block !important; width:
            100% !important; padding-right: 0 !important; } }
        </style>
    </head>
    <body>
        <div class='shell'>
            <div class='card'>
                <div class='brand'>
                    {{#if logoUrl}}
                        <img
                            src='{{logoUrl}}'
                            alt='Glee'
                            style='height:38px;width:auto;display:block;margin:0 0 14px;'
                        />
                    {{else}}
                        <div class='brand-name'>Glee</div>
                    {{/if}}
                    <div class='accent'></div>
                </div>

                <div class='section'>
                    <p class='eyebrow'>Ticket Confirmation</p>
                    <h1 class='title'>You're all set</h1>
                    <p class='copy'>Your ticket{{#if (gt noOfItems 1)}}s{{/if}} {{#if (gt noOfItems 1)}}are{{else}}is{{/if}} attached as PDF{{#if (gt noOfItems 1)}}s{{/if}}. Open and show the QR code at the gate.</p>

                    <div class='event-box'>
                        <p class='event-name'>{{productTitle}}</p>
                        <p class='meta'>
                            {{#if eventDate}}{{eventDate}}{{/if}}{{#if eventTime}} at {{eventTime}}{{/if}}{{#if eventVenue}} · {{eventVenue}}{{/if}}
                        </p>
                    </div>

                    {{#if ticketLinks.length}}
                        <div style='margin: 18px 0; text-align: center;'>
                            {{#each ticketLinks}}
                                <a href='{{this.url}}' style='display: inline-block; padding: 11px 20px; background: #7c3aed; color: #ffffff; border-radius: 10px; font-size: 13px; font-weight: 800; text-decoration: none; margin: 6px 6px 0 0;'>View Ticket {{this.ticketNumber}}</a>
                            {{/each}}
                        </div>
                    {{/if}}

                    <div class='summary'>
                        <div class='summary-head'>Order Total</div>
                        <table width='100%' cellpadding='0' cellspacing='0'>
                            {{#if menuItems.length}}
                                {{#each menuItems}}
                                    <tr>
                                        <td class='row-label'>{{this.name}} x{{this.quantity}}</td>
                                        <td class='row-value'>KES {{this.price}}</td>
                                    </tr>
                                {{/each}}
                            {{/if}}
                            <tr>
                                <td class='total-label'>Amount paid</td>
                                <td class='total-value'>KES {{total}}</td>
                            </tr>
                            {{#if paymentPlan}}
                                <tr style='border-top: 1px solid #e5e7eb; padding-top: 8px;'>
                                    <td class='row-label' style='padding-top: 8px;'>Remaining balance</td>
                                    <td class='row-value' style='padding-top: 8px;'>KES {{paymentPlan.remainingAmount}}</td>
                                </tr>
                            {{/if}}
                        </table>
                    </div>

                    {{#if paymentPlan}}
                        <div class='summary'>
                            <div class='summary-head'>Payment Schedule</div>
                            <table width='100%' cellpadding='0' cellspacing='0'>
                                <tr>
                                    <td class='row-label'>Due now</td>
                                    <td class='row-value'>KES {{paymentPlan.dueNow}}</td>
                                </tr>
                                <tr>
                                    <td class='total-label'>Final payment by</td>
                                    <td class='total-value'>{{paymentPlan.finalDueDate}}</td>
                                </tr>
                            </table>
                        </div>
                    {{/if}}

                    <p class='notice'>
                        {{#if paymentPlan}}
                            <strong>Installment rule:</strong>
                            Balance must be paid in full by
                            {{paymentPlan.finalDueDate}}.
                            <br />
                        {{/if}}
                        <strong>Entry rules:</strong>
                        Show the attached PDF QR code at the venue gate. Order
                        {{ticketId}}
                        covers
                        {{noOfItems}}
                        person{{#if (gt noOfItems 1)}}s{{/if}}. Each QR code is
                        valid for one-time entry only.
                    </p>
                </div>

                <div class='footer'>
                    Need help?
                    <a href='mailto:support@dmhub.cloud'>support@dmhub.cloud</a><br />
                    Follow the night:
                    <a href='https://instagram.com/gleeapp'>@gleeapp</a><br />
                    &copy; 2026 Glee. All rights reserved.
                </div>
            </div>
        </div>
    </body>
</html>
