<html lang='en'>
    <head>
        <meta charset='utf-8' />
        <meta name='viewport' content='width=device-width, initial-scale=1' />
        <title>Event review update</title>
    </head>
    <body
        style='margin: 0; padding: 0; background: #f5f7fb; color: #111827; font-family: Arial, Helvetica, sans-serif;'
    >
        <table role='presentation' width='100%' cellspacing='0' cellpadding='0'>
            <tr>
                <td style='padding: 32px 16px;'>
                    <table
                        role='presentation'
                        width='100%'
                        cellspacing='0'
                        cellpadding='0'
                        style='max-width: 600px; margin: 0 auto; background: #ffffff; border: 1px solid #e5e7eb; border-radius: 18px; overflow: hidden; box-shadow: 0 18px 40px rgba(17, 24, 39, 0.08);'
                    >
                        <tr>
                            <td style='padding: 28px 30px 10px;'>
                                {{#if logoUrl}}
                                    <img
                                        src='{{logoUrl}}'
                                        alt='Glee'
                                        style='height: 38px; width: auto; display: block; margin: 0 0 14px;'
                                    />
                                {{else}}
                                    <div
                                        style='font-size: 21px; font-weight: 800; color: #111827;'
                                    >Glee</div>
                                {{/if}}
                                <div
                                    style='height: 4px; width: 44px; background: #7c3aed; border-radius: 999px;'
                                ></div>
                            </td>
                        </tr>
                        <tr>
                            <td style='padding: 12px 30px 30px;'>
                                <p
                                    style='margin: 0 0 10px; color: #7c3aed; font-size: 11px; font-weight: 800; letter-spacing: 1.8px; text-transform: uppercase;'
                                >Event review</p>
                                {{#if approved}}
                                    <h1
                                        style='margin: 0 0 14px; color: #111827; font-size: 26px; line-height: 1.18; font-weight: 800;'
                                    >Your event is live</h1>
                                    <p
                                        style='margin: 0 0 20px; color: #4b5563; font-size: 15px; line-height: 1.6;'
                                    >Hello {{vendorName}}, your event
                                        <strong
                                            style='color: #111827;'
                                        >{{eventName}}</strong>
                                        has been approved and is now visible for
                                        ticket purchases.</p>
                                    <div
                                        style='margin: 0 0 22px; padding: 14px 16px; background: #ecfdf5; border: 1px solid #bbf7d0; border-radius: 12px;'
                                    >
                                        <p
                                            style='margin: 0; color: #166534; font-size: 13px; line-height: 1.6;'
                                        >You can now share the event and monitor
                                            ticket sales from the dashboard.</p>
                                    </div>
                                    <p style='margin: 0;'>
                                        <a
                                            href='{{eventUrl}}'
                                            style='display: inline-block; background: #111827; color: #ffffff; text-decoration: none; padding: 13px 18px; border-radius: 10px; font-size: 14px; font-weight: 700;'
                                        >View event</a>
                                    </p>
                                {{else}}
                                    <h1
                                        style='margin: 0 0 14px; color: #111827; font-size: 26px; line-height: 1.18; font-weight: 800;'
                                    >Your event needs changes</h1>
                                    <p
                                        style='margin: 0 0 18px; color: #4b5563; font-size: 15px; line-height: 1.6;'
                                    >Hello {{vendorName}}, your event
                                        <strong
                                            style='color: #111827;'
                                        >{{eventName}}</strong>
                                        was not approved yet.</p>
                                    {{#if reason}}
                                        <div
                                            style='margin: 0 0 22px; padding: 14px 16px; background: #fff7ed; border: 1px solid #fed7aa; border-radius: 12px;'
                                        >
                                            <p
                                                style='margin: 0 0 6px; color: #9a3412; font-size: 12px; line-height: 1.6; font-weight: 800; letter-spacing: 1px; text-transform: uppercase;'
                                            >Review note</p>
                                            <p
                                                style='margin: 0; color: #7c2d12; font-size: 13px; line-height: 1.6;'
                                            >{{reason}}</p>
                                        </div>
                                    {{/if}}
                                    <p style='margin: 0;'>
                                        <a
                                            href='{{eventUrl}}'
                                            style='display: inline-block; background: #111827; color: #ffffff; text-decoration: none; padding: 13px 18px; border-radius: 10px; font-size: 14px; font-weight: 700;'
                                        >Review event</a>
                                    </p>
                                {{/if}}
                            </td>
                        </tr>
                        <tr>
                            <td
                                style='padding: 18px 30px 24px; border-top: 1px solid #eef2f7; color: #9ca3af; font-size: 12px; line-height: 1.7;'
                            >
                                Glee Event Review ·
                                {{year}}<br />
                                Need help?
                                <a
                                    href='mailto:support@dmhub.cloud'
                                    style='color: #7c3aed; font-weight: 700; text-decoration: none;'
                                >support@dmhub.cloud</a>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </body>
</html>
