<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8">
  <meta content="width=device-width, initial-scale=1" name="viewport">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="x-apple-disable-message-reformatting">
  <meta content="telephone=no" name="format-detection">
  <title>Your Ticket — {{productTitle}}</title>
  <style type="text/css">
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; border-collapse: collapse; }
    img { -ms-interpolation-mode: bicubic; border: 0; outline: none; text-decoration: none; }
    body { margin: 0; padding: 0; background-color: #F0F4FF; }
    a { color: #7B2FBE; text-decoration: none; }

    .shell { background-color: #F0F4FF; padding: 32px 20px 48px; }
    .logo-bar { text-align: center; padding-bottom: 24px; }

    /* ── Event header (always clean — no poster image) ── */
    .event-header {
      background: linear-gradient(135deg, #1a0533 0%, #3d1278 100%);
      border-radius: 16px 16px 0 0;
      padding: 32px 32px 28px;
    }
    .event-header-eyebrow {
      color: #a78bfa;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 11px; font-weight: 700;
      letter-spacing: 2.5px; text-transform: uppercase;
      margin: 0 0 10px;
    }
    .event-header-title {
      color: #FFFFFF;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 28px; font-weight: 700;
      margin: 0 0 10px; line-height: 1.2;
    }
    .event-header-meta { color: rgba(255,255,255,0.70); font-family: Arial, Helvetica, sans-serif; font-size: 13px; margin: 0; line-height: 1.6; }
    .event-header-meta strong { color: rgba(255,255,255,0.95); }

    /* ── Greeting ── */
    .greeting-strip {
      background-color: #ffffff;
      border-left: 1px solid #e5e7f0;
      border-right: 1px solid #e5e7f0;
      padding: 20px 28px 18px;
      position: relative;
    }
    .greeting-stripe {
      position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, #7B2FBE, #FF2D8F, #FF6B35);
    }
    .greeting-banner {
      background: linear-gradient(135deg, #f0f4ff, #f9f0ff);
      border: 1px solid #ddd5f7;
      border-radius: 8px;
      padding: 12px 16px;
      margin-bottom: 12px;
    }
    .greeting-emoji { display: table-cell; width: 36px; font-size: 22px; vertical-align: middle; }
    .greeting-text {
      display: table-cell; vertical-align: middle;
      color: #1a1a2e;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 14px; line-height: 1.5;
    }
    .greeting-text strong { color: #7B2FBE; }
    .greeting-sub { color: #6b7280; font-family: Arial, Helvetica, sans-serif; font-size: 12px; line-height: 1.6; margin: 0; }

    /* ── Ticket ── */
    .ticket-outer {
      background-color: #F0F4FF;
      border-left: 1px solid #e5e7f0;
      border-right: 1px solid #e5e7f0;
      padding: 16px 20px 20px;
    }
    .ticket-inner {
      background-color: #ffffff;
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(123,47,190,0.12), 0 1px 4px rgba(0,0,0,0.06);
    }

    /* Ticket top bar */
    .ticket-topbar { background: linear-gradient(110deg, #7B2FBE 0%, #FF2D8F 100%); padding: 18px 24px; }
    .ticket-topbar-label {
      color: rgba(255,255,255,0.75);
      font-family: Arial, Helvetica, sans-serif;
      font-size: 11px; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase;
      margin: 0 0 4px;
    }
    .ticket-topbar-name {
      color: #FFFFFF;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 22px; font-weight: 700;
      margin: 0;
    }

    .ticket-body-wrap { padding: 22px 24px; }
    .ticket-detail-label {
      color: #9ca3af;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 10px; font-weight: 700;
      letter-spacing: 1.5px; text-transform: uppercase;
      margin: 0 0 3px;
    }
    .ticket-detail-value { color: #111827; font-family: Arial, Helvetica, sans-serif; font-size: 15px; font-weight: 600; margin: 0 0 16px; }
    .ticket-detail-value.small { font-size: 12px; color: #374151; word-break: break-all; }

    /* QR panel */
    .qr-panel {
      background: #ffffff;
      border: 2px solid #e9d5ff;
      border-radius: 12px;
      padding: 16px;
      text-align: center;
    }
    .qr-panel img { width: 170px; height: 170px; display: block; margin: 0 auto; border-radius: 4px; }
    .qr-hint { color: #9ca3af; font-family: Arial, Helvetica, sans-serif; font-size: 10px; letter-spacing: 0.5px; margin: 10px 0 0; text-align: center; }

    .tear-line { border: 0; border-top: 2px dashed #e5e7eb; margin: 0 20px; }

    .ref-stub { padding: 12px 20px 16px; text-align: center; background: #fafbff; }
    .ref-stub-label {
      color: #9ca3af;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 9px; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase;
      margin: 0 0 6px;
    }
    .ref-stub-code {
      color: #7B2FBE;
      font-family: 'Courier New', Courier, monospace;
      font-size: 12px; font-weight: 700;
      letter-spacing: 2.5px;
      margin: 0; word-break: break-all;
    }

    /* ── Summary ── */
    .summary-outer {
      background-color: #F0F4FF;
      border-left: 1px solid #e5e7f0;
      border-right: 1px solid #e5e7f0;
      padding: 0 20px 20px;
    }
    .summary-box { background-color: #ffffff; border-radius: 10px; overflow: hidden; }
    .summary-header { padding: 10px 16px; border-bottom: 1px solid #f3f4f6; background: #fafbff; }
    .summary-header-text {
      color: #9ca3af;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 9px; font-weight: 700;
      letter-spacing: 1.5px; text-transform: uppercase;
      margin: 0;
    }
    .summary-row { padding: 10px 16px; border-bottom: 1px solid #f9f9f9; }
    .summary-row-label { color: #6b7280; font-family: Arial, Helvetica, sans-serif; font-size: 13px; }
    .summary-row-value { color: #374151; font-family: Arial, Helvetica, sans-serif; font-size: 13px; font-weight: 600; text-align: right; }
    .summary-total-row { padding: 12px 16px; background: #fafbff; }
    .summary-total-label { color: #111827; font-family: Arial, Helvetica, sans-serif; font-size: 14px; font-weight: 700; }
    .summary-total-value { color: #7B2FBE; font-family: Arial, Helvetica, sans-serif; font-size: 16px; font-weight: 800; text-align: right; }

    /* ── Notice ── */
    .notice-outer {
      background-color: #F0F4FF;
      border-left: 1px solid #e5e7f0;
      border-right: 1px solid #e5e7f0;
      padding: 0 20px 24px;
    }
    .notice-box { background-color: #fdf4ff; border: 1px solid #e9d5ff; border-radius: 8px; padding: 12px 16px; }
    .notice-text { color: #7c3aed; font-family: Arial, Helvetica, sans-serif; font-size: 11px; line-height: 1.7; margin: 0; }
    .notice-text strong { color: #6d28d9; }
    .notice-text em { color: #4c1d95; font-style: normal; font-weight: 600; }

    /* ── Footer ── */
    .email-footer {
      background-color: #ffffff;
      border: 1px solid #e5e7f0;
      border-top: none;
      border-radius: 0 0 16px 16px;
      padding: 20px 28px;
      text-align: center;
    }
    .footer-divider { height: 1px; background: linear-gradient(90deg, transparent, #e9d5ff, transparent); margin-bottom: 16px; }
    .footer-text { color: #9ca3af; font-family: Arial, Helvetica, sans-serif; font-size: 12px; line-height: 1.7; margin: 0 0 3px; }
    .footer-link { color: #7B2FBE; font-weight: 700; text-decoration: none; }
    .footer-copy { color: #d1d5db; font-family: Arial, Helvetica, sans-serif; font-size: 11px; margin: 12px 0 0; }

    @media screen and (max-width: 480px) {
      .shell { padding: 16px 10px 32px !important; }
      .greeting-strip,
      .ticket-outer, .summary-outer, .notice-outer, .email-footer {
        padding-left: 12px !important;
        padding-right: 12px !important;
      }
      .hero-title, .fallback-title { font-size: 18px !important; }
      .ticket-topbar { padding: 12px 16px !important; }
      .ticket-body-wrap { padding: 14px 16px !important; }
      .qr-panel img { width: 130px !important; height: 130px !important; }
    }
  </style>
</head>
<body>
<div class="shell">
  <table width="600" cellpadding="0" cellspacing="0" border="0" align="center" style="max-width:600px;width:100%;">
  <tbody><tr><td>

    <!-- Logo -->
    <div class="logo-bar">
      <img src="{{logoUrl}}" alt="Glee" style="height:32px;width:auto;">
    </div>

    <!-- ── EVENT HEADER ── -->
    <div class="event-header">
      <p class="event-header-eyebrow">Event Ticket &nbsp;·&nbsp; {{orderType}}</p>
      <p class="event-header-title">{{productTitle}}</p>
      {{#if eventDate}}
      <p class="event-header-meta"><strong>{{eventDate}}</strong>{{#if eventTime}} &nbsp;·&nbsp; {{eventTime}}{{/if}}{{#if eventVenue}} &nbsp;·&nbsp; {{eventVenue}}{{/if}}</p>
      {{/if}}
    </div>

    <!-- ── GREETING ── -->
    <div class="greeting-strip">
      <div class="greeting-stripe"></div>
      <div class="greeting-banner">
        <table cellpadding="0" cellspacing="0" width="100%"><tbody><tr>
          <td class="greeting-emoji">🎉</td>
          <td class="greeting-text">Hey <strong>{{userName}}</strong>, you're in! Your ticket is confirmed.</td>
        </tr></tbody></table>
      </div>
      <p class="greeting-sub">Your ticket{{#if (gt noOfItems 1)}}s are{{else}} is{{/if}} attached as PDF{{#if (gt noOfItems 1)}}s{{/if}} to this email. Present the QR code at the venue entrance.</p>
    </div>

    <!-- ── TICKET CARD ── -->
    <div class="ticket-outer">
      <div class="ticket-inner">

        <!-- Top gradient bar -->
        <div class="ticket-topbar">
          <p class="ticket-topbar-label">{{orderType}} Ticket &nbsp;·&nbsp; {{noOfItems}}× Entry</p>
          <p class="ticket-topbar-name">{{productTitle}}</p>
        </div>

        <!-- Details + QR side by side -->
        <div class="ticket-body-wrap">
          <table width="100%" cellpadding="0" cellspacing="0">
            <tbody><tr>
              <!-- Left: attendee details -->
              <td valign="top" style="width:52%;padding-right:20px;">
                <p class="ticket-detail-label">Attendee</p>
                <p class="ticket-detail-value">{{userName}}</p>

                <p class="ticket-detail-label">Email</p>
                <p class="ticket-detail-value small">{{userEmail}}</p>

                <p class="ticket-detail-label">Purchase Date</p>
                <p class="ticket-detail-value">{{purchasedOn}}</p>

                {{#if eventDate}}
                <p class="ticket-detail-label">Date</p>
                <p class="ticket-detail-value">{{eventDate}}</p>
                {{/if}}

                {{#if eventVenue}}
                <p class="ticket-detail-label">Venue</p>
                <p class="ticket-detail-value">{{eventVenue}}</p>
                {{/if}}

                <p class="ticket-detail-label">Quantity</p>
                <p class="ticket-detail-value" style="margin-bottom:0;">{{noOfItems}} Ticket{{#if (gt noOfItems 1)}}s{{/if}}</p>
              </td>

              <!-- Right: attached PDF notice -->
              <td valign="top" style="width:48%;">
                <div class="qr-panel" style="background:#fdf4ff;border-color:#e9d5ff;">
                  <p style="font-size:36px;margin:16px 0 8px;text-align:center;">🎟️</p>
                  <p style="color:#7c3aed;font-family:Arial,Helvetica,sans-serif;font-size:12px;font-weight:700;text-align:center;margin:0 0 6px;">PDF Ticket{{#if (gt noOfItems 1)}}s{{/if}} Attached</p>
                  <p style="color:#9ca3af;font-family:Arial,Helvetica,sans-serif;font-size:10px;text-align:center;margin:0;">Check your email attachments.<br>Each PDF contains a QR code for entry.</p>
                </div>
              </td>
            </tr></tbody>
          </table>
        </div>

        <!-- Dashed tear line -->
        <hr class="tear-line">

        <!-- Reference stub -->
        <div class="ref-stub">
          <p class="ref-stub-label">Ticket ID</p>
          <p class="ref-stub-code">{{ticketId}}</p>
        </div>

      </div>
    </div><!-- /ticket-outer -->

    <!-- ── ORDER SUMMARY ── -->
    <div class="summary-outer" style="padding-top:0;">
      <div class="summary-box">
        <div class="summary-header">
          <p class="summary-header-text">Order Summary</p>
        </div>
        <table width="100%" cellpadding="0" cellspacing="0">
          <tbody>
          <tr>
            <td class="summary-row">
              <table width="100%" cellpadding="0" cellspacing="0"><tbody><tr>
                <td class="summary-row-label">{{productTitle}}</td>
                <td class="summary-row-value">{{noOfItems}} ticket{{#if (gt noOfItems 1)}}s{{/if}}</td>
              </tr></tbody></table>
            </td>
          </tr>
          <tr>
            <td class="summary-row">
              <table width="100%" cellpadding="0" cellspacing="0"><tbody><tr>
                <td class="summary-row-label">Subtotal</td>
                <td class="summary-row-value">KES {{subTotal}}</td>
              </tr></tbody></table>
            </td>
          </tr>
          <tr>
            <td class="summary-total-row">
              <table width="100%" cellpadding="0" cellspacing="0"><tbody><tr>
                <td class="summary-total-label">Total Paid</td>
                <td class="summary-total-value">KES {{total}}</td>
              </tr></tbody></table>
            </td>
          </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ── NOTICE ── -->
    <div class="notice-outer" style="padding-top:12px;">
      <div class="notice-box">
        <p class="notice-text">
          <strong>Entry rules:</strong> Open the attached PDF ticket{{#if (gt noOfItems 1)}}s{{/if}} and show the QR code at the venue gate.
          Order <em>{{ticketId}}</em> covers <em>{{noOfItems}} person{{#if (gt noOfItems 1)}}s{{/if}}</em> — each PDF is for one-time entry only.
          Tickets are non-transferable. Doors close 30 minutes after event start.
        </p>
      </div>
    </div>

    <!-- ── FOOTER ── -->
    <div class="email-footer">
      <div class="footer-divider"></div>
      <p class="footer-text">Need help? <a href="mailto:support@gleeapp.co" class="footer-link">support@gleeapp.co</a></p>
      <p class="footer-text" style="margin:0;">Follow the night &nbsp;·&nbsp; <a href="https://instagram.com/gleeapp" class="footer-link">@gleeapp</a></p>
      <p class="footer-copy">© 2026 Glee. All rights reserved. This is an automated message — please do not reply.</p>
    </div>

  </td></tr></tbody>
  </table>
</div>
</body>
</html>
