<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Glee Invitation</title>
  </head>
  <body style="font-family: Arial, sans-serif; color: #111827; margin: 0; padding: 24px; background: #f8fafc;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width: 560px; margin: 0 auto; background: #ffffff; border: 1px solid #e5e7eb;">
      <tr>
        <td style="padding: 24px;">
          {{#if logoUrl}}
            <img src="{{logoUrl}}" alt="Glee" style="height: 40px; margin-bottom: 24px;" />
          {{/if}}
          <h1 style="font-size: 22px; line-height: 1.3; margin: 0 0 16px;">You have been invited to Glee</h1>
          <p style="font-size: 15px; line-height: 1.6; margin: 0 0 16px;">Hello {{name}},</p>
          <p style="font-size: 15px; line-height: 1.6; margin: 0 0 24px;">
            You have been invited to join Glee with the {{role}} role. Use the button below to accept the invitation and set your password.
          </p>
          <p style="margin: 0 0 24px;">
            <a href="{{link}}" style="display: inline-block; background: #111827; color: #ffffff; text-decoration: none; padding: 12px 18px; font-size: 14px;">Accept invitation</a>
          </p>
          <p style="font-size: 13px; line-height: 1.6; color: #6b7280; margin: 0;">
            If the button does not work, open this link: {{link}}
          </p>
        </td>
      </tr>
    </table>
  </body>
</html>
