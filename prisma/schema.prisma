generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATIONS_MANAGER
  COMMERCIAL_MANAGER
  FINANCE
  VENDOR
  VENDOR_STAFF
  CUSTOMER_SUPPORT
  CONTENT_MANAGER
  USER
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

enum EntityStatus {
  ACTIVE
  DONE
  SUSPENDED
  INACTIVE
}

// ─── RBAC ─────────────────────────────────────────────────────────────────────

model Role {
  id          String           @id @default(cuid())
  name        UserRole         @unique
  description String?
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  module      String
  action      String
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─── Core ─────────────────────────────────────────────────────────────────────

model User {
  id                  String        @id @default(cuid())
  name                String
  email               String        @unique
  phone               String?
  password            String
  roleId              String?
  role                Role?         @relation(fields: [roleId], references: [id])
  isActive            AccountStatus @default(ACTIVE)
  profileImage        String?
  token               String?
  refreshToken        String?
  otp                 Int?
  address             String?
  profileStatus       Boolean       @default(true)
  notificationStatus  Boolean       @default(true)
  haveNewNotification Boolean       @default(false)
  isDeleted           Boolean       @default(false)
  deletedAt           DateTime?
  playerId            String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([email])
  @@index([isDeleted])
}

// ─── Events ───────────────────────────────────────────────────────────────────

model Event {
  id                 String       @id @default(cuid())
  name               String
  description        String?
  price              Decimal      @db.Decimal(10, 2)
  capacity           Int?
  maxTicketPurchased Int?
  availableTickets   Int?
  locationName       String?
  city               String?
  state              String?
  country            String?
  latitude           Float?
  longitude          Float?
  bannerImages       String[]
  photos             String[]
  floorPlan          String?
  startDate          DateTime?
  endDate            DateTime?
  status             EntityStatus @default(ACTIVE)
  suspended          Boolean      @default(false)
  isDeleted          Boolean      @default(false)
  deletedAt          DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  locationId         String?
  location           Location?    @relation(fields: [locationId], references: [id])

  @@index([isDeleted])
}

// ─── Locations ────────────────────────────────────────────────────────────────

model Location {
  id                 String       @id @default(cuid())
  name               String
  address            String
  capacity           Int
  isIndoors          Boolean      @default(false)
  isOutdoors         Boolean      @default(false)
  latitude           Float
  longitude          Float
  floorPlanImageUrl  String?
  pictures           String[]
  isParkingAvailable Boolean      @default(false)
  status             EntityStatus @default(ACTIVE)
  events             Event[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@map("locations")
}
