generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATIONS_MANAGER
  COMMERCIAL_MANAGER
  FINANCE
  VENDOR
  VENDOR_STAFF
  CUSTOMER_SUPPORT
  CONTENT_MANAGER
  USER
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

enum EntityStatus {
  ACTIVE
  DONE
  SUSPENDED
  INACTIVE
}

enum EventStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  LIVE
  ENDED
  POSTPONED
  CANCELLED
  REJECTED
  SOLD_OUT
}

enum TicketWaveStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TicketStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELLED
}

enum TicketAttendantStatus {
  INVITED
  ACTIVE
  REVOKED
  EXPIRED
}

enum TicketCheckInAttemptResult {
  SUCCESS
  DUPLICATE
  WRONG_EVENT
  EXPIRED
  CANCELLED
  UNKNOWN
  NOT_LIVE
}

enum TicketCheckInAttemptSource {
  QR
  MANUAL
}

enum NotificationType {
  CHAT
  EVENT_TICKET
  BOOKING
  SERVICE
}

enum EventChatRoomStatus {
  ACTIVE
  READ_ONLY
  LOCKED
}

enum EventChatMessageType {
  MESSAGE
  ANNOUNCEMENT
  SYSTEM
}

// ─── RBAC ─────────────────────────────────────────────────────────────────────

model Role {
  id                String           @id @default(cuid())
  name              UserRole         @unique
  description       String?
  twoFactorRequired Boolean          @default(false)
  permissions       RolePermission[]
  users             User[]
  invitations       UserInvitation[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  module      String
  action      String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─── Core ─────────────────────────────────────────────────────────────────────

model User {
  id                   String        @id @default(cuid())
  name                 String
  email                String        @unique
  phone                String?
  password             String
  passwordChangedAt    DateTime?
  passwordRotationDays Int           @default(30)
  roleId               String?
  role                 Role?         @relation(fields: [roleId], references: [id])
  isActive             AccountStatus @default(ACTIVE)
  profileImage         String?
  token                String?
  refreshToken         String?
  twoFactorEnabled     Boolean       @default(false)
  twoFactorCode        Int?
  twoFactorExpiresAt   DateTime?
  twoFactorVerifiedAt  DateTime?
  invitedById          String?
  invitedAt            DateTime?
  lastLoginAt          DateTime?
  vendorAccountId      String?
  otp                  Int?
  address              String?
  profileStatus        Boolean       @default(true)
  notificationStatus   Boolean       @default(true)
  haveNewNotification  Boolean       @default(false)
  notificationIds      String[]
  isDeleted            Boolean       @default(false)
  deletedAt            DateTime?
  playerId             String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  invitedBy            User?         @relation("UserInvites", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedUsers         User[]        @relation("UserInvites")
  vendorAccount        User?         @relation("VendorStaff", fields: [vendorAccountId], references: [id], onDelete: SetNull)
  vendorStaff          User[]        @relation("VendorStaff")

  eventTickets            EventTicket[]
  checkedInTickets        EventTicket[]          @relation("TicketCheckedInBy")
  wallet                  Wallet?
  notifications           Notification[]
  auditLogs               AuditLog[]             @relation("AuditActor")
  invitationsSent         UserInvitation[]       @relation("InvitationInviter")
  invitation              UserInvitation?
  vendorEvents            Event[]                @relation("EventVendor")
  vendorLocations         Location[]             @relation("LocationVendor")
  createdTicketAttendants EventTicketAttendant[] @relation("TicketAttendantCreatedBy")
  ticketCheckInAttempts   TicketCheckInAttempt[] @relation("TicketCheckInAttemptUser")
  eventChatMessages        EventChatMessage[]    @relation("EventChatMessageSender")
  deletedEventChatMessages EventChatMessage[]    @relation("EventChatMessageDeletedBy")
  eventChatReadStates      EventChatReadState[]

  @@index([email])
  @@index([isDeleted])
  @@index([invitedById])
  @@index([vendorAccountId])
}

model UserInvitation {
  id          String    @id @default(cuid())
  email       String
  name        String
  phone       String?
  token       String    @unique
  status      String    @default("PENDING")
  expiresAt   DateTime
  acceptedAt  DateTime?
  roleId      String
  role        Role      @relation(fields: [roleId], references: [id])
  invitedById String?
  invitedBy   User?     @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: SetNull)
  userId      String?   @unique
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([email])
  @@index([status])
  @@index([roleId])
  @@index([invitedById])
  @@map("user_invitations")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Events ───────────────────────────────────────────────────────────────────

model Event {
  id               String                 @id @default(cuid())
  name             String
  description      String?
  capacity         Int                    @default(0)
  photos           String[]
  startDate        DateTime?
  endDate          DateTime?
  status           EventStatus            @default(DRAFT)
  isDeleted        Boolean                @default(false)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  locationId       String?
  categoryId       String?
  vendorId         String?
  location         Location?              @relation(fields: [locationId], references: [id])
  category         Category?              @relation(fields: [categoryId], references: [id])
  vendor           User?                  @relation("EventVendor", fields: [vendorId], references: [id], onDelete: SetNull)
  ticketWaves      TicketWave[]
  ticketCategories TicketCategory[]
  eventTickets     EventTicket[]
  menuItems        EventMenuItem[]
  schedules        EventSchedule[]
  ticketAttendants EventTicketAttendant[]
  attendantSessions EventTicketAttendantSession[]
  checkInAttempts  TicketCheckInAttempt[]
  chatRoom         EventChatRoom?
  chatMessages     EventChatMessage[]
  chatReadStates   EventChatReadState[]

  @@index([isDeleted])
  @@index([vendorId])
}

model TicketWave {
  id               String           @id @default(cuid())
  eventId          String
  event            Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name             String
  description      String?
  sequence         Int              @default(1)
  startsAt         DateTime
  endsAt           DateTime
  status           TicketWaveStatus @default(UPCOMING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  ticketCategories TicketCategory[]

  @@index([eventId, sequence])
  @@index([eventId, status])
  @@index([startsAt, endsAt])
  @@map("ticket_waves")
}

model EventSchedule {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([eventId])
  @@index([startDate])
  @@map("event_schedules")
}

model EventMenuItem {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  category    String   @default("other")
  price       Decimal  @db.Decimal(10, 2)
  description String?
  createdAt   DateTime @default(now())

  @@map("event_menu_items")
}

model TicketCategory {
  id           String        @id @default(cuid())
  eventId      String
  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  waveId       String?
  wave         TicketWave?   @relation(fields: [waveId], references: [id], onDelete: Cascade)
  name         String
  price        Decimal       @db.Decimal(10, 2)
  capacity     Int?
  available    Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  eventTickets EventTicket[]

  @@index([waveId])
  @@map("ticket_categories")
}

// ─── Categories ───────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]
}

// ─── Locations ────────────────────────────────────────────────────────────────

model Location {
  id                 String       @id @default(cuid())
  name               String
  address            String
  description        String?
  capacity           Int
  isIndoors          Boolean      @default(false)
  isOutdoors         Boolean      @default(false)
  latitude           Float
  longitude          Float
  floorPlanImageUrl  String?
  pictures           String[]
  isParkingAvailable Boolean      @default(false)
  status             EntityStatus @default(ACTIVE)
  vendorId           String?
  vendor             User?        @relation("LocationVendor", fields: [vendorId], references: [id], onDelete: SetNull)
  events             Event[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([vendorId])
  @@map("locations")
}

// ─── Tickets & Payments ───────────────────────────────────────────────────────

model Payment {
  id                String        @id @default(cuid())
  userId            String
  paystackReference String        @unique
  paymentStatus     String
  paymentMethod     String
  totalPrice        Decimal       @db.Decimal(10, 2)
  perItemPrice      Decimal       @db.Decimal(10, 2)
  noOfItems         Int           @default(1)
  isPaid            Boolean       @default(false)
  isAvailable       Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  eventTickets      EventTicket[]

  @@map("payments")
}

model EventTicket {
  id                     String                 @id @default(cuid())
  eventId                String
  userId                 String
  paymentId              String
  ticketCategoryId       String?
  checkedInById          String?
  checkedInByAttendantId String?
  purchaseGroupId        String
  ticketRef              String                 @unique
  publicAccessToken      String?                @unique
  ticketNumber           Int                    @default(1)
  status                 TicketStatus           @default(ACTIVE)
  quantity               Int                    @default(1)
  totalPrice             Decimal                @db.Decimal(10, 2)
  amountPaid             Decimal                @default(0) @db.Decimal(10, 2)
  outstandingAmount      Decimal                @default(0) @db.Decimal(10, 2)
  paymentDueDate         DateTime?
  paymentPlan            Json?
  preOrderMenu           Json?
  guestName              String?
  guestEmail             String?
  guestPhone             String?
  checkedInAt            DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  event                  Event                  @relation(fields: [eventId], references: [id])
  user                   User                   @relation(fields: [userId], references: [id])
  payment                Payment                @relation(fields: [paymentId], references: [id])
  ticketCategory         TicketCategory?        @relation(fields: [ticketCategoryId], references: [id])
  checkedInBy            User?                  @relation("TicketCheckedInBy", fields: [checkedInById], references: [id], onDelete: SetNull)
  checkedInByAttendant   EventTicketAttendant?  @relation("TicketCheckedInByAttendant", fields: [checkedInByAttendantId], references: [id], onDelete: SetNull)
  checkInAttempts        TicketCheckInAttempt[]
  notifications          Notification[]

  @@index([checkedInById])
  @@index([checkedInByAttendantId])
  @@index([checkedInAt])
  @@index([purchaseGroupId])
  @@index([status])
  @@map("event_tickets")
}

model EventTicketAttendant {
  id              String                        @id @default(cuid())
  eventId         String
  event           Event                         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name            String
  email           String
  pinHash         String
  inviteTokenHash String                        @unique
  status          TicketAttendantStatus         @default(INVITED)
  lastSessionId   String?
  sessionActive   Boolean                       @default(false)
  lastLoginAt     DateTime?
  createdById     String?
  createdBy       User?                         @relation("TicketAttendantCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
  revokedAt       DateTime?
  sessions        EventTicketAttendantSession[]
  checkedTickets  EventTicket[]                 @relation("TicketCheckedInByAttendant")
  checkInAttempts TicketCheckInAttempt[]

  @@index([eventId])
  @@index([email])
  @@index([status])
  @@map("event_ticket_attendants")
}

model EventTicketAttendantSession {
  id               String               @id @default(cuid())
  attendantId      String
  attendant        EventTicketAttendant @relation(fields: [attendantId], references: [id], onDelete: Cascade)
  eventId          String
  event            Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sessionTokenHash String               @unique
  deviceLabel      String?
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime             @default(now())
  lastSeenAt       DateTime?

  @@index([attendantId])
  @@index([eventId])
  @@index([expiresAt])
  @@map("event_ticket_attendant_sessions")
}

model EventChatRoom {
  id                String              @id @default(cuid())
  eventId           String              @unique
  event             Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status            EventChatRoomStatus @default(ACTIVE)
  finalUpdatesUntil DateTime?
  lockedAt          DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  messages          EventChatMessage[]
  readStates        EventChatReadState[]

  @@unique([id, eventId])
  @@index([status])
  @@index([finalUpdatesUntil])
  @@map("event_chat_rooms")
}

model EventChatMessage {
  id           String               @id @default(cuid())
  roomId       String
  eventId      String
  senderId     String?
  type         EventChatMessageType @default(MESSAGE)
  body         String
  isPinned     Boolean              @default(false)
  deletedAt    DateTime?
  deletedById  String?
  deleteReason String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  room         EventChatRoom        @relation(fields: [roomId, eventId], references: [id, eventId], onDelete: Cascade)
  event        Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sender       User?                @relation("EventChatMessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  deletedBy    User?                @relation("EventChatMessageDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  readStates   EventChatReadState[] @relation("EventChatReadStateLastReadMessage")

  @@unique([id, roomId, eventId])
  @@index([roomId, createdAt])
  @@index([roomId, isPinned, createdAt])
  @@index([eventId])
  @@index([senderId])
  @@index([deletedAt])
  @@map("event_chat_messages")
}

model EventChatReadState {
  id                String        @id @default(cuid())
  roomId            String
  eventId           String
  userId            String
  lastReadMessageId String?
  lastReadAt        DateTime      @default(now())
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  room              EventChatRoom @relation(fields: [roomId, eventId], references: [id, eventId], onDelete: Cascade)
  event             Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadMessage   EventChatMessage? @relation("EventChatReadStateLastReadMessage", fields: [lastReadMessageId, roomId, eventId], references: [id, roomId, eventId], onDelete: SetNull)

  @@unique([roomId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([lastReadMessageId])
  @@map("event_chat_read_states")
}

model TicketCheckInAttempt {
  id             String                     @id @default(cuid())
  eventId        String
  event          Event                      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketId       String?
  ticket         EventTicket?               @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  attendantId    String?
  attendant      EventTicketAttendant?      @relation(fields: [attendantId], references: [id], onDelete: SetNull)
  platformUserId String?
  platformUser   User?                      @relation("TicketCheckInAttemptUser", fields: [platformUserId], references: [id], onDelete: SetNull)
  result         TicketCheckInAttemptResult
  source         TicketCheckInAttemptSource
  metadata       Json?
  createdAt      DateTime                   @default(now())

  @@index([eventId])
  @@index([ticketId])
  @@index([attendantId])
  @@index([result])
  @@index([createdAt])
  @@map("ticket_check_in_attempts")
}

model Wallet {
  id           String              @id @default(cuid())
  userId       String              @unique
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Decimal             @default(0) @db.Decimal(10, 2)
  currency     String              @default("KES")
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id           String   @id @default(cuid())
  walletId     String
  wallet       Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  paymentId    String?
  type         String
  amount       Decimal  @db.Decimal(10, 2)
  balanceAfter Decimal  @db.Decimal(10, 2)
  description  String?
  reference    String?  @unique
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

// ─── Services ─────────────────────────────────────────────────────────────────

model Service {
  id                String             @id @default(cuid())
  name              String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  purchasedServices PurchasedService[]

  @@map("services")
}

model PurchasedService {
  id            String         @id @default(cuid())
  serviceId     String
  service       Service        @relation(fields: [serviceId], references: [id])
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("purchased_services")
}

// ─── Bookings ─────────────────────────────────────────────────────────────────

model Booking {
  id                String             @id @default(cuid())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  purchasedBookings PurchasedBooking[]

  @@map("bookings")
}

model PurchasedBooking {
  id            String         @id @default(cuid())
  bookingId     String
  booking       Booking        @relation(fields: [bookingId], references: [id])
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("purchased_bookings")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id                 String            @id @default(cuid())
  userId             String?
  type               NotificationType
  isRead             Boolean           @default(false)
  eventTicketId      String?
  purchasedServiceId String?
  purchasedBookingId String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  user               User?             @relation(fields: [userId], references: [id])
  eventTicket        EventTicket?      @relation(fields: [eventTicketId], references: [id])
  purchasedService   PurchasedService? @relation(fields: [purchasedServiceId], references: [id])
  purchasedBooking   PurchasedBooking? @relation(fields: [purchasedBookingId], references: [id])

  @@map("notifications")
}
