generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATIONS_MANAGER
  COMMERCIAL_MANAGER
  FINANCE
  VENDOR
  VENDOR_STAFF
  CUSTOMER_SUPPORT
  CONTENT_MANAGER
  USER
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

enum EntityStatus {
  ACTIVE
  DONE
  SUSPENDED
  INACTIVE
}

enum NotificationType {
  CHAT
  EVENT_TICKET
  BOOKING
  SERVICE
}

// ─── RBAC ─────────────────────────────────────────────────────────────────────

model Role {
  id          String           @id @default(cuid())
  name        UserRole         @unique
  description String?
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  module      String
  action      String
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─── Core ─────────────────────────────────────────────────────────────────────

model User {
  id                  String        @id @default(cuid())
  name                String
  email               String        @unique
  phone               String?
  password            String
  roleId              String?
  role                Role?         @relation(fields: [roleId], references: [id])
  isActive            AccountStatus @default(ACTIVE)
  profileImage        String?
  token               String?
  refreshToken        String?
  otp                 Int?
  address             String?
  profileStatus       Boolean       @default(true)
  notificationStatus  Boolean       @default(true)
  haveNewNotification Boolean       @default(false)
  isAllChatRead       Boolean       @default(true)
  notificationIds     String[]
  isDeleted           Boolean       @default(false)
  deletedAt           DateTime?
  playerId            String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  chatsSent      Chat[]         @relation("ChatSender")
  chatsReceived  Chat[]         @relation("ChatReceiver")
  blocksGiven    UserBlock[]    @relation("Blocker")
  blocksReceived UserBlock[]    @relation("Blocked")
  eventTickets   EventTicket[]
  notifications  Notification[]

  @@index([email])
  @@index([isDeleted])
}

// ─── Events ───────────────────────────────────────────────────────────────────

model Event {
  id                 String           @id @default(cuid())
  name               String
  description        String?
  price              Decimal          @db.Decimal(10, 2)
  capacity           Int?
  maxTicketPurchased Int?
  availableTickets   Int?
  locationName       String?
  city               String?
  state              String?
  country            String?
  latitude           Float?
  longitude          Float?
  bannerImages       String[]
  photos             String[]
  floorPlan          String?
  startDate          DateTime?
  endDate            DateTime?
  status             EntityStatus     @default(ACTIVE)
  suspended          Boolean          @default(false)
  isDeleted          Boolean          @default(false)
  deletedAt          DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  locationId         String?
  categoryId         String?
  location           Location?        @relation(fields: [locationId], references: [id])
  category           Category?        @relation(fields: [categoryId], references: [id])
  ticketCategories   TicketCategory[]
  eventTickets       EventTicket[]
  menuItems          EventMenuItem[]

  @@index([isDeleted])
}

model EventMenuItem {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  category    String   @default("other")
  price       Decimal  @db.Decimal(10, 2)
  description String?
  createdAt   DateTime @default(now())

  @@map("event_menu_items")
}

model TicketCategory {
  id           String        @id @default(cuid())
  eventId      String
  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String
  price        Decimal       @db.Decimal(10, 2)
  capacity     Int?
  available    Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  eventTickets EventTicket[]

  @@map("ticket_categories")
}

// ─── Categories ───────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]
}

// ─── Locations ────────────────────────────────────────────────────────────────

model Location {
  id                 String       @id @default(cuid())
  name               String
  address            String
  description        String?
  capacity           Int
  isIndoors          Boolean      @default(false)
  isOutdoors         Boolean      @default(false)
  latitude           Float
  longitude          Float
  floorPlanImageUrl  String?
  pictures           String[]
  isParkingAvailable Boolean      @default(false)
  status             EntityStatus @default(ACTIVE)
  events             Event[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@map("locations")
}

// ─── Tickets & Payments ───────────────────────────────────────────────────────

model Payment {
  id                String      @id @default(cuid())
  userId            String
  paystackReference String      @unique
  paymentStatus     String
  paymentMethod     String
  totalPrice        Decimal     @db.Decimal(10, 2)
  perItemPrice      Decimal     @db.Decimal(10, 2)
  noOfItems         Int         @default(1)
  isPaid            Boolean     @default(false)
  isAvailable       Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  eventTicket       EventTicket?

  @@map("payments")
}

model EventTicket {
  id               String           @id @default(cuid())
  eventId          String
  userId           String
  paymentId        String           @unique
  ticketCategoryId String?
  quantity         Int              @default(1)
  totalPrice       Decimal          @db.Decimal(10, 2)
  preOrderMenu     Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  event            Event            @relation(fields: [eventId], references: [id])
  user             User             @relation(fields: [userId], references: [id])
  payment          Payment          @relation(fields: [paymentId], references: [id])
  ticketCategory   TicketCategory?  @relation(fields: [ticketCategoryId], references: [id])
  notifications    Notification[]

  @@map("event_tickets")
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model Chat {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  message    String
  isRead     Boolean  @default(false)
  sender     User     @relation("ChatSender", fields: [senderId], references: [id])
  receiver   User     @relation("ChatReceiver", fields: [receiverId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("chats")
}

model UserBlock {
  blockerId String
  blockedId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id])
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id])
  createdAt DateTime @default(now())

  @@id([blockerId, blockedId])
  @@map("user_blocks")
}

// ─── Services ─────────────────────────────────────────────────────────────────

model Service {
  id                String             @id @default(cuid())
  name              String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  purchasedServices PurchasedService[]

  @@map("services")
}

model PurchasedService {
  id            String         @id @default(cuid())
  serviceId     String
  service       Service        @relation(fields: [serviceId], references: [id])
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("purchased_services")
}

// ─── Bookings ─────────────────────────────────────────────────────────────────

model Booking {
  id                String             @id @default(cuid())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  purchasedBookings PurchasedBooking[]

  @@map("bookings")
}

model PurchasedBooking {
  id            String         @id @default(cuid())
  bookingId     String
  booking       Booking        @relation(fields: [bookingId], references: [id])
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("purchased_bookings")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id                 String            @id @default(cuid())
  userId             String?
  type               NotificationType
  isRead             Boolean           @default(false)
  eventTicketId      String?
  purchasedServiceId String?
  purchasedBookingId String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  user               User?             @relation(fields: [userId], references: [id])
  eventTicket        EventTicket?      @relation(fields: [eventTicketId], references: [id])
  purchasedService   PurchasedService? @relation(fields: [purchasedServiceId], references: [id])
  purchasedBooking   PurchasedBooking? @relation(fields: [purchasedBookingId], references: [id])

  @@map("notifications")
}
