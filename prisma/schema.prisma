generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATIONS_MANAGER
  COMMERCIAL_MANAGER
  FINANCE
  VENDOR
  VENDOR_STAFF
  CUSTOMER_SUPPORT
  CONTENT_MANAGER
  USER
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

enum VendorStatus {
  ACTIVE
  INACTIVE
}

enum EntityStatus {
  ACTIVE
  DONE
  SUSPENDED
  INACTIVE
}

enum PaymentStatus {
  SUCCEEDED
  PENDING
  FAILED
}

enum PaymentMethod {
  PAYSTACK
  WALLET
  CASH
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum NotificationType {
  CHAT
  EVENT_TICKET
  SERVICE
  BOOKING
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaStatus {
  ACTIVE
  INACTIVE
}

enum MediaAccess {
  PUBLIC
  PRIVATE
}

enum BookingType {
  STANDARD
  TABLE
}

// ─── Core ─────────────────────────────────────────────────────────────────────

model User {
  id                  String        @id @default(cuid())
  name                String
  email               String        @unique
  phone               String?
  password            String
  roleId              String?
  role                Role?         @relation(fields: [roleId], references: [id])
  isActive            AccountStatus @default(ACTIVE)
  profileImage        String?
  token               String?
  refreshToken        String?
  otp                 Int?
  margin              Float?
  adminContactInfo    Json?
  address             String?
  cityId              Int?
  city                City?         @relation(fields: [cityId], references: [id])
  stateId             Int?
  state               State?        @relation(fields: [stateId], references: [id])
  countryId           Int?
  country             Country?      @relation(fields: [countryId], references: [id])
  vendorId            String?
  vendor              Vendor?       @relation(fields: [vendorId], references: [id])
  profileStatus       Boolean       @default(true)
  notificationIds     String[]
  notificationStatus  Boolean       @default(true)
  isAllChatRead       Boolean       @default(true)
  haveNewNotification Boolean       @default(false)
  isDeleted           Boolean       @default(false)
  deletedAt           DateTime?
  playerId            String?
  walletOtpToken      String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  blockedUsers        UserBlock[]         @relation("blocker")
  blockedByUsers      UserBlock[]         @relation("blocked")
  notifications       Notification[]
  sentMessages        Chat[]              @relation("sender")
  receivedMessages    Chat[]              @relation("receiver")
  eventTickets        EventTicket[]
  purchasedServices   PurchasedService[]
  purchasedBookings   PurchasedBooking[]
  payments            Payment[]
  wallet              Wallet?
  reminders           Reminder[]
  bankAccounts        UserBankAccount[]

  @@index([email])
  @@index([isDeleted])
}

model UserBlock {
  blockerId String
  blockedId String
  blocker   User   @relation("blocker", fields: [blockerId], references: [id])
  blocked   User   @relation("blocked", fields: [blockedId], references: [id])

  @@id([blockerId, blockedId])
}

model Vendor {
  id              String       @id @default(cuid())
  name            String
  email           String       @unique
  phone           String?
  address         String?
  state           String?
  country         String?
  city            String?
  profileImage    String?
  routingNumber   String?
  businessAccount String?
  status          VendorStatus @default(ACTIVE)
  isDeleted       Boolean      @default(false)
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  users    User[]
  events   Event[]
  services Service[]
  bookings Booking[]
  payments Payment[]
  media    Media[]
  payouts  Payout[]

  @@index([isDeleted])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  events   Event[]
  services Service[]
  bookings Booking[]
}

// ─── Events ───────────────────────────────────────────────────────────────────

model Event {
  id                 String       @id @default(cuid())
  name               String
  vendorId           String?
  vendor             Vendor?      @relation(fields: [vendorId], references: [id])
  categoryId         String?
  category           Category?    @relation(fields: [categoryId], references: [id])
  description        String?
  price              Decimal      @db.Decimal(10, 2)
  capacity           Int?
  maxTicketPurchased Int?
  availableTickets   Int?
  location           String?
  city               String?
  state              String?
  country            String?
  latitude           Float?
  longitude          Float?
  bannerImages       String[]
  photos             String[]
  floorPlan          String?
  startDate          DateTime?
  endDate            DateTime?
  status             EntityStatus @default(ACTIVE)
  suspended          Boolean      @default(false)
  isDeleted          Boolean      @default(false)
  deletedAt          DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  schedules        EventSchedule[]
  tickets          EventTicket[]
  ticketCategories TicketCategory[]
  artists          Artist[]
  preOrderMenus    PreOrderMenu[]

  @@index([isDeleted])
  @@index([vendorId])
}

model EventSchedule {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
}

model TicketCategory {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  price     Decimal  @db.Decimal(10, 2)
  capacity  Int?
  available Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets EventTicket[]
}

model EventTicket {
  id               String          @id @default(cuid())
  eventId          String
  event            Event           @relation(fields: [eventId], references: [id])
  userId           String
  user             User            @relation(fields: [userId], references: [id])
  ticketCategoryId String?
  ticketCategory   TicketCategory? @relation(fields: [ticketCategoryId], references: [id])
  quantity         Int             @default(1)
  totalPrice       Decimal         @db.Decimal(10, 2)
  paymentId        String?
  payment          Payment?        @relation("TicketPayment", fields: [paymentId], references: [id])
  depositPaymentId String?
  depositPayment   Payment?        @relation("TicketDepositPayment", fields: [depositPaymentId], references: [id])
  depositAmount    Decimal?        @db.Decimal(10, 2)
  depositPaid      Boolean         @default(false)
  preOrderMenu     Json?
  createdAt        DateTime        @default(now())

  notifications Notification[]
  qrCodes       QrCode[]
}

// ─── Services ─────────────────────────────────────────────────────────────────

model Service {
  id             String       @id @default(cuid())
  name           String
  vendorId       String
  vendor         Vendor       @relation(fields: [vendorId], references: [id])
  categoryId     String?
  category       Category?    @relation(fields: [categoryId], references: [id])
  description    String?
  price          Decimal      @db.Decimal(10, 2)
  address        String?
  latitude       Float?
  longitude      Float?
  photos         String[]
  serviceDetails Json?
  status         EntityStatus @default(ACTIVE)
  isDeleted      Boolean      @default(false)
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  purchasedServices PurchasedService[]

  @@index([isDeleted])
  @@index([vendorId])
}

model PurchasedService {
  id               String    @id @default(cuid())
  serviceId        String
  service          Service   @relation(fields: [serviceId], references: [id])
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  paymentId        String?
  payment          Payment?  @relation("ServicePayment", fields: [paymentId], references: [id])
  depositPaymentId String?
  depositPayment   Payment?  @relation("ServiceDepositPayment", fields: [depositPaymentId], references: [id])
  depositAmount    Decimal?  @db.Decimal(10, 2)
  depositPaid      Boolean   @default(false)
  quantity         Int       @default(1)
  date             DateTime?
  createdAt        DateTime  @default(now())

  notifications Notification[]
}

// ─── Bookings ─────────────────────────────────────────────────────────────────

model Booking {
  id             String       @id @default(cuid())
  name           String
  vendorId       String
  vendor         Vendor       @relation(fields: [vendorId], references: [id])
  categoryId     String?
  category       Category?    @relation(fields: [categoryId], references: [id])
  address        String?
  description    String?
  price          Decimal      @db.Decimal(10, 2)
  capacity       Int?
  startTime      DateTime
  endTime        DateTime
  latitude       Float?
  longitude      Float?
  photos         String[]
  bookingDetails Json?
  status         EntityStatus @default(ACTIVE)
  isDeleted      Boolean      @default(false)
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  tables            BookingTable[]
  purchasedBookings PurchasedBooking[]
  preOrderMenus     PreOrderMenu[]

  @@index([isDeleted])
  @@index([vendorId])
}

model BookingTable {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  name      String?
  capacity  Int?
  status    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchasedBooking {
  id               String      @id @default(cuid())
  bookingId        String
  booking          Booking     @relation(fields: [bookingId], references: [id])
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  paymentId        String?
  payment          Payment?    @relation("BookingPayment", fields: [paymentId], references: [id])
  depositPaymentId String?
  depositPayment   Payment?    @relation("BookingDepositPayment", fields: [depositPaymentId], references: [id])
  depositAmount    Decimal?    @db.Decimal(10, 2)
  depositPaid      Boolean     @default(false)
  bookingType      BookingType @default(STANDARD)
  tableId          String?
  preOrderMenu     Json?
  createdAt        DateTime    @default(now())

  notifications Notification[]
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id                String        @id @default(cuid())
  transactionId     String?       @unique
  paystackReference String?       @unique
  bankAccountNumber String?
  paymentStatus     PaymentStatus @default(PENDING)
  paymentMethod     PaymentMethod @default(PAYSTACK)
  noOfItems         Int           @default(1)
  totalPrice        Decimal       @db.Decimal(10, 2)
  perItemPrice      Decimal       @db.Decimal(10, 2)
  commission        Float         @default(0)
  isPaid            Boolean       @default(false)
  isAvailable       Boolean       @default(false)
  userId            String?
  user              User?         @relation(fields: [userId], references: [id])
  vendorId          String?
  vendor            Vendor?       @relation(fields: [vendorId], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  eventTickets      EventTicket[]      @relation("TicketPayment")
  depositedTickets  EventTicket[]      @relation("TicketDepositPayment")
  purchasedServices PurchasedService[] @relation("ServicePayment")
  depositedServices PurchasedService[] @relation("ServiceDepositPayment")
  purchasedBookings PurchasedBooking[] @relation("BookingPayment")
  depositedBookings PurchasedBooking[] @relation("BookingDepositPayment")
  walletHistory     WalletPaymentHistory[]
}

// ─── Wallet ───────────────────────────────────────────────────────────────────

model Wallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  points      Float    @default(0)
  refPrice    Float    @default(0)
  refCurrency String   @default("USD")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  paymentHistory WalletPaymentHistory[]
}

model WalletPaymentHistory {
  id        String          @id @default(cuid())
  walletId  String
  wallet    Wallet          @relation(fields: [walletId], references: [id])
  paymentId String?
  payment   Payment?        @relation(fields: [paymentId], references: [id])
  points    Float
  type      TransactionType @default(CREDIT)
  createdAt DateTime        @default(now())
}

// ─── QR Codes ─────────────────────────────────────────────────────────────────

model QrCode {
  id            String      @id @default(cuid())
  code          String      @unique
  eventTicketId String?
  eventTicket   EventTicket? @relation(fields: [eventTicketId], references: [id])
  isUsed        Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

// ─── Payout ───────────────────────────────────────────────────────────────────

model Payout {
  id          String   @id @default(cuid())
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  amount      Decimal  @db.Decimal(10, 2)
  isPaid      Boolean  @default(false)
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())
}

// ─── Pre-Order Menus ──────────────────────────────────────────────────────────

model PreOrderMenu {
  id        String   @id @default(cuid())
  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  name      String
  price     Decimal  @db.Decimal(10, 2)
  available Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Artist ───────────────────────────────────────────────────────────────────

model Artist {
  id           String   @id @default(cuid())
  eventId      String?
  event        Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String
  profileImage String?
  images       String[]
  videos       String[]
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Media ────────────────────────────────────────────────────────────────────

model Media {
  id        String      @id @default(cuid())
  url       String
  type      MediaType
  status    MediaStatus @default(ACTIVE)
  access    MediaAccess @default(PUBLIC)
  vendorId  String?
  vendor    Vendor?     @relation(fields: [vendorId], references: [id])
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

// ─── Currency ─────────────────────────────────────────────────────────────────

model Currency {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  exchangeRate Float
  isEnabled    Boolean  @default(true)
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Language ─────────────────────────────────────────────────────────────────

model Language {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isEnabled Boolean  @default(true)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Reminder ─────────────────────────────────────────────────────────────────

model Reminder {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  body        String?
  scheduledAt DateTime
  isSent      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─── User Bank Account ────────────────────────────────────────────────────────

model UserBankAccount {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  bankName      String
  accountName   String
  accountNumber String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
}

// ─── Chat & Notifications ─────────────────────────────────────────────────────

model Chat {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("sender", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("receiver", fields: [receiverId], references: [id])
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId, receiverId])
}

model Notification {
  id                 String            @id @default(cuid())
  type               NotificationType
  userId             String?
  user               User?             @relation(fields: [userId], references: [id])
  isRead             Boolean           @default(false)
  eventTicketId      String?
  eventTicket        EventTicket?      @relation(fields: [eventTicketId], references: [id])
  purchasedServiceId String?
  purchasedService   PurchasedService? @relation(fields: [purchasedServiceId], references: [id])
  purchasedBookingId String?
  purchasedBooking   PurchasedBooking? @relation(fields: [purchasedBookingId], references: [id])
  createdAt          DateTime          @default(now())
}

// ─── Geo Data ─────────────────────────────────────────────────────────────────

model Country {
  id      Int     @id @default(autoincrement())
  name    String
  isoCode String  @unique
  states  State[]
  users   User[]
}

model State {
  id        Int     @id @default(autoincrement())
  name      String
  isoCode   String
  countryId Int
  country   Country @relation(fields: [countryId], references: [id])
  cities    City[]
  users     User[]

  @@index([countryId])
}

model City {
  id      Int    @id @default(autoincrement())
  name    String
  stateId Int
  state   State  @relation(fields: [stateId], references: [id])
  users   User[]

  @@index([stateId])
}

// ─── RBAC ─────────────────────────────────────────────────────────────────────

model Role {
  id          String           @id @default(cuid())
  name        UserRole         @unique
  description String?
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  module      String
  action      String
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}
