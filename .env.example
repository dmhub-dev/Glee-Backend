# App
NODE_ENV=development
PORT=8003
APP_NAME="Glee API"
APP_URL=http://localhost:8003
APP_BASE_URL=http://localhost:3021
ADMIN_APP_URL=http://localhost:3021

# Auth
SECRETKEY=your_jwt_secret_key
EXPIRESIN=1d

# PostgreSQL (Prisma)
POSTGRES_DB=glee
POSTGRES_USER=glee
POSTGRES_PASSWORD=glee_password
DATABASE_URL=postgresql://glee:glee_password@postgres:5432/glee

# Docker
APP_PORT=8003
APP_IMAGE=glee-backend:latest

# Resend email
RESEND_API_KEY=re_xxx
RESEND_FROM="Glee <no-reply@yourdomain.com>"

# AWS S3 uploads
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=your_s3_bucket_name

# Legacy SMTP settings kept for config compatibility
MAIL_PORT=2525
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_USERNAME=your_mail_username
MAIL_PASSWORD=your_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your@email.com

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_REDIRECT_URI=https://your-api-url.com/stripe/oauth/callback
STRIPE_CLIENT_ID=your_stripe_client_id
STRIPE_ENDPOINT_SECRET=whsec_your_stripe_endpoint_secret

# OneSignal (push notifications)
ONE_SIGNAL_APP_ID=your_onesignal_app_id
ONE_SIGNAL_API_KEY=your_onesignal_api_key

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_WEBHOOK_URL=http://localhost:8003/api/v1/paystack/webhook
PAYSTACK_CALLBACK_URL=http://localhost:8003/payment/callback
PAYSTACK_VERIFICATION_TOKEN_SECRET=change_me
